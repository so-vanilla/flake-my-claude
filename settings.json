{
  "language": "japanese",

  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },

  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },

  "permissions": {

    "allow": [],

    "deny": [
      "Bash(rm *)",

      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/credentials.json)",
      "Read(**/secrets.yaml)",
      "Read(**/secrets.yml)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.keystore)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/.ssh/config)",
      "Read(**/.netrc)",
      "Read(**/.npmrc)",
      "Read(**/.pypirc)",

      "Edit(~/.config/**)",
      "Write(~/.config/**)",
      "Edit(~/.local/**)",
      "Write(~/.local/**)",
      "Edit(~/.ssh/**)",
      "Write(~/.ssh/**)",
      "Edit(~/.gnupg/**)",
      "Write(~/.gnupg/**)",
      "Edit(~/.emacs.d/**)",
      "Write(~/.emacs.d/**)",
      "Edit(~/.nix-defexpr/**)",
      "Write(~/.nix-defexpr/**)",
      "Edit(~/.nix-profile/**)",
      "Write(~/.nix-profile/**)",

      "Edit(~/.claude/settings.json)",
      "Write(~/.claude/settings.json)",
      "Edit(~/.claude/settings.local.json)",
      "Write(~/.claude/settings.local.json)",
      "Edit(~/.claude/keybindings.json)",
      "Write(~/.claude/keybindings.json)",
      "Edit(~/.claude/skills/**)",
      "Write(~/.claude/skills/**)",

      "Edit(~/Desktop/**)",
      "Write(~/Desktop/**)",
      "Edit(~/Documents/**)",
      "Write(~/Documents/**)",
      "Edit(~/Downloads/**)",
      "Write(~/Downloads/**)",
      "Edit(~/Music/**)",
      "Write(~/Music/**)",
      "Edit(~/Pictures/**)",
      "Write(~/Pictures/**)",
      "Edit(~/Videos/**)",
      "Write(~/Videos/**)",
      "Edit(~/Templates/**)",
      "Write(~/Templates/**)",
      "Edit(~/Public/**)",
      "Write(~/Public/**)",

      "Edit(//etc/**)",
      "Write(//etc/**)",
      "Edit(//nix/**)",
      "Write(//nix/**)",
      "Edit(//usr/**)",
      "Write(//usr/**)",
      "Edit(//var/**)",
      "Write(//var/**)",
      "Edit(//boot/**)",
      "Write(//boot/**)",
      "Edit(//sys/**)",
      "Write(//sys/**)",
      "Edit(//proc/**)",
      "Write(//proc/**)",

      "Bash(git push --force *)",
      "Bash(git push --force)",
      "Bash(git push -f *)",
      "Bash(git push -f)",
      "Bash(git reset --hard *)",
      "Bash(git reset --hard)",
      "Bash(git clean -f *)",
      "Bash(git clean -f)",
      "Bash(git clean -fd *)",
      "Bash(git clean -df *)",
      "Bash(git checkout -- .)",
      "Bash(git checkout .)",
      "Bash(git restore .)",
      "Bash(git branch -D *)",
      "Bash(git branch -d --force *)",
      "Bash(git rebase -i *)",
      "Bash(git rebase --interactive *)",

      "Bash(rm -rf /*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf ~/)",
      "Bash(chmod -R *)",
      "Bash(chown -R *)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(pkill *)",
      "Bash(kill -9 *)",
      "Bash(killall *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(systemctl *)",
      "Bash(dd *)",

      "Bash(npm install -g *)",
      "Bash(npm i -g *)",
      "Bash(pip install *)",
      "Bash(pip3 install *)",
      "Bash(gem install *)",
      "Bash(cargo install *)",

      "Bash(nix-env --install *)",
      "Bash(nix-env -i *)",
      "Bash(nix-env --uninstall *)",
      "Bash(nix-env -e *)",
      "Bash(nix-env --upgrade *)",
      "Bash(nix-env -u *)"
    ]
  },

  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/session-status.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/session-status.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/session-status.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/session-status.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/session-status.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/session-status.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/session-status.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/log-permission-request.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },

  "mcpServers": {
    "voicevox": {
      "type": "stdio",
      "command": "nix",
      "args": ["run", "/home/somura/repos/github.com/so-vanilla/voicevox-claude"],
      "env": {
        "ALL_PROXY": "",
        "all_proxy": "",
        "HTTP_PROXY": "",
        "http_proxy": "",
        "HTTPS_PROXY": "",
        "https_proxy": ""
      }
    }
  },

  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true,
    "ralph-wiggum@anthropics/claude-code": true
  }
}
